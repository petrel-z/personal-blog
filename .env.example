# Database
DATABASE_URL="mysql://user:password@localhost:3306/blog"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Optional: AI Summary
# GEMINI_API_KEY="your-gemini-api-key"

# Storage (local or oss)
# STORAGE_PROVIDER="local"  # local or oss
# OSS Configuration (when STORAGE_PROVIDER="oss")
# OSS_ACCESS_KEY_ID="your-access-key-id"
# OSS_ACCESS_KEY_SECRET="your-access-key-secret"
# OSS_BUCKET="your-bucket-name"
# OSS_REGION="oss-cn-wulanchabu"
# OSS_ENDPOINT="oss-cn-wulanchabu.aliyuncs.com"
# OSS_CDN_DOMAIN="https://your-cdn-domain.com"  # Optional CDN domain
